{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "description": "Export Gemini and ChatGPT chats to Markdown with perfect LaTeX math, code, and formatting.",
  "version": "4.0.1",
  "permissions": [
    "clipboardRead",
    "storage",
    "alarms",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
  "https://gemini.google.com/*",
  "https://chatgpt.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/lib/turndown.js", "src/content_scripts/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["src/content_scripts/chatgpt.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  }
}
